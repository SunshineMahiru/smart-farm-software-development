# 自动检测文本文件，并规范化为 LF（提交到仓库统一用 LF）
* text=auto

# 强制指定这几类文件使用 LF（特别针对你的前后端项目）
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf

*.js text eol=lf
*.vue text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf

# 🌟 关键：把 .vscode 下的配置文件也强制锁定为 LF
.vscode/* text eol=lf

# 二进制文件（防止 Git 乱改图片）
*.png binary
*.jpg binary
*.ico binary